---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Blog Chaveiro Itajaí - Dicas de Segurança";
const description = "Acompanhe nosso blog e fique por dentro das melhores dicas de segurança residencial e automotiva em Itajaí e região.";
---

<Layout title={title} description={description}>
	<Header />
	<main class="page-content">
		<div class="page-header">
			<div class="container">
				<h1>Blog de Segurança</h1>
				<p>Dicas, novidades e informações essenciais para a sua proteção.</p>
			</div>
		</div>

		<section class="blog-section">
			<div class="container">
				<div class="blog-grid">
					{
						posts.map((post) => (
							<article class="blog-card">
								<a href={`/blog/${post.slug}/`}>
									<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									<div class="blog-card-content">
										<p class="date">
											{post.data.pubDate.toLocaleDateString('pt-BR')}
										</p>
										<h2 class="title">{post.data.title}</h2>
										<p class="description">{post.data.description}</p>
										<span class="read-more">Ler artigo completo →</span>
									</div>
								</a>
							</article>
						))
					}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-header { background: #1a1a1a; color: white; padding: 100px 0 60px; text-align: center; }
	.page-header h1 { font-size: 2.5rem; margin-bottom: 10px; color: var(--primary); }
	.page-header p { font-size: 1.2rem; color: #ccc; }
	
	.blog-section {
		padding: 80px 0;
		background-color: var(--gray);
		min-height: 50vh;
	}
	
	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 40px;
	}
	
	.blog-card {
		background: #ffffff;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(0,0,0,0.05);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}
	
	.blog-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.1);
	}
	
	.blog-card a {
		text-decoration: none;
		color: inherit;
		display: block;
		height: 100%;
	}
	
	.blog-card img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		border-bottom: 3px solid var(--primary);
	}
	
	.blog-card-content {
		padding: 25px;
	}
	
	.date {
		color: #888;
		font-size: 0.9rem;
		margin-bottom: 10px;
		font-weight: 500;
	}
	
	.title {
		font-size: 1.4rem;
		margin-bottom: 15px;
		color: #1a1a1a;
		line-height: 1.4;
	}
	
	.blog-card:hover .title {
		color: var(--primary-dark);
	}
	
	.description {
		color: #555;
		font-size: 1rem;
		line-height: 1.6;
		margin-bottom: 20px;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	
	.read-more {
		display: inline-block;
		color: var(--primary-dark);
		font-weight: 700;
		font-size: 0.95rem;
		text-transform: uppercase;
		margin-top: auto;
	}
</style>
