---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Footer from '../components/Footer.astro';

const title = "Chaveiro Itajaí 24 Horas | Especialista em Alta Segurança";
const description = "Atendimento profissional de chaveiro 24 horas em Itajaí, Navegantes e Balneário Camboriú. Especialista em aberturas, fechaduras digitais e chaves automotivas.";
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<Hero />
		<Services />
		
		<section id="sobre" class="about">
			<div class="container about-inner">
				<div class="about-image animate-fade">
					<img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?q=80&w=1200&auto=format&fit=crop" alt="Chaveiro Profissional trabalhando em fechadura" />
					<div class="experience-badge">
						<span class="exp-years">+20</span>
						<span class="exp-text">Anos de Experiência</span>
					</div>
				</div>
				<div class="about-text animate-fade" style="animation-delay: 0.2s;">
					<span class="section-badge">Nossa História</span>
					<h2>Líder em <span class="text-gradient">Segurança Técnica</span> na Região</h2>
					<p>Nossa equipe é altamente treinada e equipada com as ferramentas mais modernas do mercado para resolver qualquer problema com fechaduras, chaves e controles de acesso.</p>
					
					<div class="benefits-list">
						<div class="benefit-item">
							<span class="benefit-icon">⏱️</span>
							<div class="benefit-content">
								<h4>Agilidade Extrema</h4>
								<p>Chegamos em até 30 minutos em Itajaí e cidades vizinhas.</p>
							</div>
						</div>
						<div class="benefit-item">
							<span class="benefit-icon">👮</span>
							<div class="benefit-content">
								<h4>Segurança Total</h4>
								<p>Profissionais identificados e com procedência garantida.</p>
							</div>
						</div>
						<div class="benefit-item">
							<span class="benefit-icon">🛠️</span>
							<div class="benefit-content">
								<h4>Tecnologia de Ponta</h4>
								<p>Ferramentas que abrem e reparam sem danificar seu patrimônio.</p>
							</div>
						</div>
					</div>

					<a href="https://wa.me/5547999999999" class="btn btn-primary">Falar com um Especialista</a>
				</div>
			</div>
		</section>
		
		<section id="emergencia" class="emergency-cta">
			<div class="container">
				<div class="glass-card emergency-box animate-fade">
					<div class="emergency-content">
						<h2>Perdeu a chave ou está trancado para fora?</h2>
						<p>Não entre em pânico. Nossa equipe de plantão está pronta para sair agora mesmo.</p>
						<div class="emergency-actions">
							<a href="tel:+5547999999999" class="btn btn-primary btn-large">
								📞 Ligar Agora: (47) 99999-9999
							</a>
							<span class="emergency-note">Atendimento disponível em इटजाई, Navegantes e Balneário Camboriú</span>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />

	<a href="https://wa.me/5547999999999" class="whatsapp-float" target="_blank" aria-label="WhatsApp">
		<svg width="35" height="35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-11.7 a8.38 8.38 0 0 1 3.8.9L21 2z"></path></svg>
	</a>
</Layout>

<style>
	/* About Section */
	.about {
		padding: 120px 0;
		background: var(--dark);
	}

	.about-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
	}

	.about-image {
		position: relative;
	}

	.about-image img {
		width: 100%;
		border-radius: 24px;
		box-shadow: 0 30px 60px rgba(0,0,0,0.5);
	}

	.experience-badge {
		position: absolute;
		bottom: -30px;
		right: -30px;
		background: var(--primary);
		padding: 30px;
		border-radius: 24px;
		text-align: center;
		box-shadow: 0 20px 40px var(--primary-glow);
		color: var(--dark);
	}

	.exp-years {
		display: block;
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 1;
	}

	.exp-text {
		font-size: 0.9rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.section-badge {
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		margin-bottom: 15px;
		display: block;
	}

	.about-text h2 {
		font-size: 3rem;
		margin-bottom: 25px;
		line-height: 1.2;
	}

	.about-text p {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin-bottom: 40px;
	}

	.benefits-list {
		display: flex;
		flex-direction: column;
		gap: 30px;
		margin-bottom: 50px;
	}

	.benefit-item {
		display: flex;
		gap: 20px;
	}

	.benefit-icon {
		font-size: 1.8rem;
		flex-shrink: 0;
	}

	.benefit-content h4 {
		font-size: 1.2rem;
		margin-bottom: 5px;
	}

	.benefit-content p {
		font-size: 0.95rem;
		margin-bottom: 0;
	}

	/* Emergency Section */
	.emergency-cta {
		padding: 60px 0 120px;
	}

	.emergency-box {
		padding: 80px 40px;
		text-align: center;
		background: linear-gradient(135deg, rgba(255, 215, 0, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
	}

	.emergency-box h2 {
		font-size: 2.5rem;
		margin-bottom: 20px;
	}

	.emergency-box p {
		font-size: 1.2rem;
		color: var(--text-muted);
		margin-bottom: 40px;
	}

	.emergency-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
	}

	.btn-large {
		padding: 20px 45px;
		font-size: 1.2rem;
	}

	.emergency-note {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	@media (max-width: 992px) {
		.about-inner {
			grid-template-columns: 1fr;
			gap: 60px;
			text-align: center;
		}
		.about-image {
			order: 2;
			max-width: 600px;
			margin: 0 auto;
		}
		.experience-badge {
			right: 20px;
			bottom: 20px;
			padding: 20px;
		}
		.benefits-list {
			text-align: left;
		}
	}

	@media (max-width: 768px) {
		.about-text h2 { font-size: 2rem; }
		.emergency-box h2 { font-size: 1.8rem; }
	}
</style>
