<footer class="main-footer">
	<div class="container footer-grid">
		<div class="footer-col col-info">
			<h3>CHAVEIRO <strong>ITAJAÍ</strong></h3>
			<p>Somos especialistas em soluções de segurança e abertura de portas residenciais e automotivas há mais de 20 anos atendendo Itajaí, Navegantes e região com agilidade e profissionalismo.</p>
		</div>
		
		<div class="footer-col">
			<h4>Links Rápidos</h4>
			<ul>
				<li><a href="/">Início</a></li>
				<li><a href="#servicos">Serviços</a></li>
				<li><a href="#sobre">Sobre Nós</a></li>
				<li><a href="#contato">Contato</a></li>
			</ul>
		</div>
		
		<div class="footer-col">
			<h4>Serviços</h4>
			<ul>
				<li><a href="#">Residencial</a></li>
				<li><a href="#">Automotivo</a></li>
				<li><a href="#">Comercial</a></li>
				<li><a href="#">Cofres</a></li>
			</ul>
		</div>
		
		<div class="footer-col">
			<h4>Contato</h4>
			<p>📍 Itajaí, SC</p>
			<p>📞 (47) 99999-9999</p>
			<p>📧 contato@chaveiroitajai.com.br</p>
			<p>🕒 24 Horas por dia / 7 dias</p>
		</div>
	</div>
	
	<div class="footer-bottom">
		<div class="container flex justify-between items-center text-center">
			<p>&copy; {new Date().getFullYear()} Chaveiro Residencial 24 Horas. Todos os direitos reservados.</p>
		</div>
	</div>
</footer>

<style>
	.main-footer {
		background-color: var(--dark);
		color: var(--light);
		padding: 80px 0 0 0;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 60px;
		margin-bottom: 60px;
	}
	.footer-col h3 {
		font-size: 1.5rem;
		margin-bottom: 25px;
	}
	.footer-col h3 strong {
		color: var(--primary);
	}
	.footer-col h4 {
		font-size: 1.2rem;
		margin-bottom: 25px;
		color: var(--primary);
	}
	.footer-col p {
		color: #bbb;
		font-size: 0.95rem;
		line-height: 1.8;
	}
	.footer-col ul {
		list-style: none;
	}
	.footer-col ul li {
		margin-bottom: 12px;
	}
	.footer-col ul a {
		text-decoration: none;
		color: #bbb;
		transition: color 0.3s;
		font-size: 0.95rem;
	}
	.footer-col ul a:hover {
		color: var(--primary);
	}
	.footer-bottom {
		border-top: 1px solid #333;
		padding: 30px 0;
		font-size: 0.9rem;
		color: #888;
	}
	.flex {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.text-center {
		text-align: center;
	}
	.justify-between {
		justify-content: space-between;
	}

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 40px;
		}
	}
</style>
